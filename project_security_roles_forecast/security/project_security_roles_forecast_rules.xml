<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Keep default Planning behavior for non-project users/managers, but scope Project/User. -->
        <function model="ir.rule" name="write">
            <value model="ir.rule" search="[('id', '=', ref('planning.planning_rule_internal_user_read'))]"/>
            <value eval="{
                'domain_force': &quot;(not user.has_group('project.group_project_user') or user.has_group('project.group_project_manager')) and ['|', ('user_id', '=', user.id), '|', ('resource_id', '=', False), ('request_to_switch', '=', True), ('state', '=', 'published')] or ['|', '|', ('project_id.user_id', '=', user.id), ('project_id.message_partner_ids', 'in', [user.partner_id.id]), ('project_id.collaborator_ids.partner_id', '=', user.partner_id.id)]&quot;
            }"/>
        </function>

        <function model="ir.rule" name="write">
            <value model="ir.rule" search="[('id', '=', ref('planning.planning_rule_user_is_published'))]"/>
            <value eval="{
                'domain_force': &quot;(not user.has_group('project.group_project_user') or user.has_group('project.group_project_manager')) and [('state', '=', 'published')] or ['|', '|', ('project_id.user_id', '=', user.id), ('project_id.message_partner_ids', 'in', [user.partner_id.id]), ('project_id.collaborator_ids.partner_id', '=', user.partner_id.id)]&quot;
            }"/>
        </function>

        <function model="ir.rule" name="write">
            <value model="ir.rule" search="[('id', '=', ref('planning.planning_rule_manager'))]"/>
            <value eval="{
                'domain_force': &quot;(not user.has_group('project.group_project_user') or user.has_group('project.group_project_manager')) and [(1, '=', 1)] or [('project_id.user_id', '=', user.id)]&quot;
            }"/>
        </function>

        <record id="rule_planning_slot_template_project_user_read" model="ir.rule">
            <field name="name">Planning Template Project User Read</field>
            <field name="model_id" ref="planning.model_planning_slot_template"/>
            <field name="domain_force">['|', '|', ('project_id.user_id', '=', user.id), ('project_id.message_partner_ids', 'in', [user.partner_id.id]), ('project_id.collaborator_ids.partner_id', '=', user.partner_id.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('project.group_project_user'))]"/>
        </record>
    </data>
</odoo>
