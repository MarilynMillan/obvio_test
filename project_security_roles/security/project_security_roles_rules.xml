            <value model="ir.rule" search="[('id', '=', ref('project.task_visibility_rule'))]"/>
            <value eval="{
                'domain_force': &quot;['|', ('project_id.user_id', '=', user.id), ('user_ids', 'in', user.id)]&quot;,
