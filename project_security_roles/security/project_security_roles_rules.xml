<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Restrict standard employee-level visibility so Project/User rules can be effective. -->
        <function model="ir.rule" name="write">
            <value model="ir.rule" search="[('id', '=', ref('project.task_visibility_rule_project_user'))]"/>
            <value eval="{
                'domain_force': &quot;['|', ('project_id.user_id', '=', user.id), ('user_ids', 'in', user.id)]&quot;,
                'perm_read': True,
                'perm_write': False,
                'perm_create': False,
                'perm_unlink': False
            }"/>
        </function>
        <!-- Also patch the equivalent rule introduced by project_todo when present. -->
        <function model="ir.rule" name="write">
            <value model="ir.rule" search="[
                ('model_id', '=', ref('project.model_project_task')),
                ('name', '=', 'Project/Task: project users: follow required for follower-only projects'),
                ('groups', 'in', [ref('project.group_project_user')])
            ]"/>
            <value eval="{
                'domain_force': &quot;['|', ('project_id.user_id', '=', user.id), ('user_ids', 'in', user.id)]&quot;,
                'perm_read': True,
                'perm_write': False,
                'perm_create': False,
                'perm_unlink': False
            }"/>
        </function>

