                'perm_write': True,
                'perm_create': True,
                'perm_unlink': True
            }"/>
        </function>

        <function model="ir.rule" name="write">
            <value model="ir.rule" search="[('id', '=', ref('project.task_type_visibility_rule'))]"/>
            <value eval="{
                'domain_force': &quot;['|', '|', '|', '|', ('user_id', 'in', (False, user.id)), ('project_ids', '=', False), ('project_ids.user_id', '=', user.id), ('project_ids.message_partner_ids', 'in', [user.partner_id.id]), ('project_ids.collaborator_ids.partner_id', '=', user.partner_id.id)]&quot;,
                'perm_read': True,
                'perm_write': False,
                'perm_create': False,
                'perm_unlink': False
            }"/>
        </function>

        <record id="rule_task_type_user_create" model="ir.rule">
            <field name="name">Own Project Task Stages Create</field>
            <field name="model_id" ref="project.model_project_task_type"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="False"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('project.group_project_user'))]"/>
        </record>

        <function model="ir.rule" name="write">
