        </function>

        <function model="ir.rule" name="write">
            <value model="ir.rule" search="[('id', '=', ref('project.task_type_own_write_rule'))]"/>
            <value eval="{
                'domain_force': &quot;['|', ('user_id', '=', user.id), ('project_ids.user_id', '=', user.id)]&quot;,
