<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="rule_timesheet_forecast_report_project_user_scoped_read" model="ir.rule">
            <field name="name">Project Timesheet Forecast Report Scoped Read</field>
            <field name="model_id" ref="project_timesheet_forecast.model_project_timesheet_forecast_report_analysis"/>
            <field name="domain_force">['|', '|', ('project_id.user_id', '=', user.id), ('project_id.message_partner_ids', 'in', [user.partner_id.id]), ('project_id.collaborator_ids.partner_id', '=', user.partner_id.id)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('project.group_project_user'))]"/>
        </record>

        <record id="rule_timesheet_forecast_report_project_manager_full_read" model="ir.rule">
            <field name="name">Project Timesheet Forecast Report Manager Full Read</field>
            <field name="model_id" ref="project_timesheet_forecast.model_project_timesheet_forecast_report_analysis"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
            <field name="groups" eval="[(4, ref('project.group_project_manager'))]"/>
        </record>
    </data>
</odoo>
